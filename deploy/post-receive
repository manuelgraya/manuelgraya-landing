#!/bin/sh
# Hook post-receive: despliega la web al hacer push.
# Vive en el servidor: ~/repos/landing.git/hooks/post-receive
WEB_ROOT="/srv/landing"
GIT_DIR="$HOME/repos/landing.git"

while read oldrev newrev refname; do
    if [ "$refname" = "refs/heads/main" ]; then
        echo ">> Desplegando main en $WEB_ROOT ..."
        git --work-tree="$WEB_ROOT" --git-dir="$GIT_DIR" checkout -f main
        # Sustituye __BASE_URL__ por la URL pública, guardada fuera del repo
        # en $GIT_DIR/base-url (una línea, sin barra final)
        if [ -f "$GIT_DIR/base-url" ]; then
            BASE_URL=$(cat "$GIT_DIR/base-url")
            find "$WEB_ROOT" \( -name '*.html' -o -name 'sitemap.xml' -o -name 'robots.txt' \) \
                -exec sed -i "s|__BASE_URL__|$BASE_URL|g" {} +
            echo ">> __BASE_URL__ -> $BASE_URL"
        fi
        # La API de contacto corre desde el web root: hay que reiniciarla para
        # que cargue el código nuevo (necesita sudo sin contraseña o hacerlo a mano)
        sudo -n systemctl restart landing-contacto 2>/dev/null \
            && echo ">> Servicio landing-contacto reiniciado" \
            || echo ">> AVISO: reinicia la API a mano: sudo systemctl restart landing-contacto"
        echo ">> Despliegue completado: $(date '+%Y-%m-%d %H:%M:%S')"
    fi
done
